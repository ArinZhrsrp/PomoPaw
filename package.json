{
  "name": "pomopaw",
  "version": "1.0.0",
  "description": "Cute pomodoro desktop app with Electron",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.yourname.pomopaw",
    "productName": "PomoPaw",
    "files": [
      "main.js",
      "preload.js",
      "app.html",
      "app.css",
      "app.js",
      "landing.html",
      "landing.css",
      "renderer.js",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.productivity"
    }
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1"
  }
}
